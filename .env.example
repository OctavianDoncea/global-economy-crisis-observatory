# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=observatory

# Used by application code (Python ingestion clients, dbt)
OBSERVATORY_DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/observatory

# API keys
# Get a free key in 60 seconds: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Optional — only needed if you swap GDELT for GNews. Free tier: 100 req/day.
# https://gnews.io
GNEWS_API_KEY=

# Airflow
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# Optional — Slack webhook for ingestion alerts
SLACK_WEBHOOK_URL=